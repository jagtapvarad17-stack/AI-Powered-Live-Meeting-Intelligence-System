{
  "name": "ai-meeting-intelligence",
  "version": "1.0.0",
  "description": "AI Meeting Intelligence System",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:renderer": "cd renderer && npm run dev",
    "transcribe": "python python/audio_transcriber.py",
    "build:renderer": "cd renderer && npm run build",
    "install:all": "npm install && cd renderer && npm install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2",
    "form-data": "^4.0.0",
    "groq-sdk": "^1.1.2",
    "mongoose": "^8.0.3",
    "node-wav": "^0.0.2",
    "openai": "^4.20.1",
    "screenshot-desktop": "^1.15.0"
  }
}
